APP_PORT=8080
APP_ENV=development
# For Docker Compose (optional; defaults in compose): POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB, POSTGRES_PORT
DATABASE_URL=host=db user=postgres password=postgres dbname=hackbuddy port=5432 sslmode=disable
JWT_SECRET=your_secret_key_change_me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GROQ_API_KEY=your_groq_api_key
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
# Production (e.g. Render): set RESEND_API_KEY to send via Resend (HTTPS) — avoids blocked SMTP ports
RESEND_API_KEY=
RESEND_FROM=HackBuddy <onboarding@resend.dev>
FRONTEND_URL=http://localhost:3000
# Base URL of this API (for OAuth redirect_uri). Must match how the app is reached (e.g. https://api.example.com).
BACKEND_URL=http://localhost:8080
# Optional: comma-separated domains for scraping (empty = allow any except private/metadata)
ALLOWED_SCRAPE_DOMAINS=
